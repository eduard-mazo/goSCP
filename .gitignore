# ─────────────────────────────────────────────────────────────
# Go
# ─────────────────────────────────────────────────────────────
# Build output / binaries
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
goscp
goscp-*

# Test & coverage
*.test
*.out
coverage.*
profile.*

# Go workspace
go.work
go.work.sum

# Vendored deps (uncomment if not vendoring)
# /vendor/

# ─────────────────────────────────────────────────────────────
# Embedded frontend build output (regenerated by `make web`)
# ─────────────────────────────────────────────────────────────
/internal/assets/dist/*
!/internal/assets/dist/.gitkeep

# ─────────────────────────────────────────────────────────────
# Frontend (Node / Vite / Vue)
# ─────────────────────────────────────────────────────────────
node_modules/
/web/node_modules/
/web/dist/
/web/.vite/
/web/.cache/
*.tsbuildinfo
.eslintcache

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Local env / overrides
*.local
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────────
# Logs & runtime artifacts
# ─────────────────────────────────────────────────────────────
*.log
logs/
*.pid
*.seed
tmp/
temp/

# ─────────────────────────────────────────────────────────────
# OS / editor
# ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-workspace
*.sublime-project
